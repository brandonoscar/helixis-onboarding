# Optional overrides — the canonical helixis-test Supabase project and the
# deployed AgenticHelixis backend are baked in as defaults (src/lib/supabase.ts
# and src/lib/api.ts), so a fresh clone runs with no .env at all.
#
# Note the VITE_HELIXIS_* names: the plain VITE_SUPABASE_* vars are ignored on
# purpose (the Vercel project carries stale values pointing at the retired
# onboarding Supabase project).
# VITE_HELIXIS_SUPABASE_URL=https://shwwcxkeewpotnigwvqp.supabase.co
# VITE_HELIXIS_SUPABASE_ANON_KEY=...
# VITE_API_URL=http://localhost:8000
